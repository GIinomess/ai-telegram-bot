# ── Telegram ───────────────────────────────────────────────────────────────
# Bot token from @BotFather
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram channel ID for subscription verification
# Format: @username  or  -100xxxxxxxxxx (numeric)
CHANNEL_ID=@your_channel

# ── Database ───────────────────────────────────────────────────────────────
# PostgreSQL async connection URL
DATABASE_URL=postgresql+asyncpg://postgres:changeme@postgres:5432/ai_bot

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── AI Providers ───────────────────────────────────────────────────────────
# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini API key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Limits ─────────────────────────────────────────────────────────────────
# Free messages per user per day (default: 40)
FREE_DAILY_LIMIT=40

# ── Telegram Stars pricing ─────────────────────────────────────────────────
# Prices are in Telegram Stars (XTR)
PREMIUM_MONTHLY_STARS=200
PREMIUM_QUARTERLY_STARS=500
PREMIUM_YEARLY_STARS=1800

# ── Docker Postgres ─────────────────────────────────────────────────────────
# Used by the postgres service in docker-compose.yml
POSTGRES_PASSWORD=changeme
